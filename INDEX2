<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Piano Editoriale — Paola Iodice Gyrotonic</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --black:#0a0a0a;
  --white:#fafaf8;
  --cream:#f4f1eb;
  --gold:#c9a96e;
  --gold-light:#e8d5b0;
  --gray:#888;
  --gray-light:#e8e6e1;
  --radius:2px;
}
body{font-family:'DM Sans',sans-serif;background:var(--white);color:var(--black);min-height:100vh}

/* HEADER */
.site-header{background:var(--black);padding:2rem 3rem;display:flex;justify-content:space-between;align-items:center}
.logo-area h1{font-family:'Cormorant Garamond',serif;font-weight:300;font-size:1.6rem;color:var(--white);letter-spacing:0.08em}
.logo-area p{font-size:0.72rem;color:var(--gold);letter-spacing:0.2em;text-transform:uppercase;margin-top:2px}
.header-meta{text-align:right}
.header-meta p{font-size:0.72rem;color:#666;letter-spacing:0.1em;text-transform:uppercase;line-height:1.8}
.header-meta span{color:var(--gold)}

/* HERO BAND */
.hero-band{background:var(--cream);padding:2.5rem 3rem;border-bottom:1px solid var(--gray-light);display:flex;gap:3rem;align-items:flex-start}
.hero-text h2{font-family:'Cormorant Garamond',serif;font-size:2.4rem;font-weight:300;line-height:1.2;margin-bottom:0.5rem}
.hero-text h2 em{font-style:italic;color:var(--gold)}
.hero-text p{font-size:0.82rem;color:var(--gray);line-height:1.7;max-width:480px}
.hero-stats{display:flex;gap:2rem;flex-shrink:0}
.stat{text-align:center}
.stat-num{font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:300;color:var(--black);display:block}
.stat-label{font-size:0.68rem;color:var(--gray);letter-spacing:0.15em;text-transform:uppercase}

/* LEGEND */
.legend-bar{padding:1rem 3rem;background:var(--white);border-bottom:1px solid var(--gray-light);display:flex;gap:1.5rem;align-items:center;flex-wrap:wrap}
.legend-bar span{font-size:0.7rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--gray)}
.tag{display:inline-flex;align-items:center;gap:5px;font-size:0.68rem;letter-spacing:0.1em;text-transform:uppercase;padding:3px 10px;border-radius:20px;font-weight:500}
.tag-foto{background:#f0ede6;color:#5a4a2a;border:1px solid #d4c9a8}
.tag-grafica{background:#ede6f0;color:#3a2a5a;border:1px solid #c8a8d4}
.tag-video{background:#e6f0ed;color:#1a4a3a;border:1px solid #a8d4c4}
.tag-reel{background:#f0e6e6;color:#5a1a1a;border:1px solid #d4a8a8}
.tag-parlato{background:#e6edf0;color:#1a3a5a;border:1px solid #a8c4d4}

/* MAIN LAYOUT */
main{padding:2rem 3rem;max-width:1100px}

/* WEEK SECTION */
.week-section{margin-bottom:3rem}
.week-header{display:flex;align-items:baseline;gap:1rem;margin-bottom:1.2rem;padding-bottom:0.8rem;border-bottom:1px solid var(--black)}
.week-num{font-family:'Cormorant Garamond',serif;font-size:3rem;font-weight:300;line-height:1;color:var(--gray-light)}
.week-info h3{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:400}
.week-info p{font-size:0.75rem;color:var(--gray);letter-spacing:0.08em;text-transform:uppercase;margin-top:2px}
.week-dates{margin-left:auto;font-size:0.72rem;color:var(--gold);letter-spacing:0.1em;text-transform:uppercase}

/* POST CARDS */
.posts-grid{display:grid;gap:1px;background:var(--gray-light);border:1px solid var(--gray-light)}
.post-card{background:var(--white);display:grid;grid-template-columns:70px 100px 1fr auto;gap:0;min-height:90px}
.post-card:hover{background:var(--cream)}
.post-day{padding:1rem;display:flex;flex-direction:column;justify-content:center;align-items:center;border-right:1px solid var(--gray-light);background:var(--cream)}
.post-day .day-name{font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--gray)}
.post-day .day-date{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:300;line-height:1}
.post-type-col{padding:1rem;display:flex;flex-direction:column;justify-content:center;gap:6px;border-right:1px solid var(--gray-light)}
.post-content{padding:1rem 1.2rem;display:flex;flex-direction:column;gap:6px;justify-content:center}
.post-title-label{font-size:0.65rem;color:var(--gray);letter-spacing:0.12em;text-transform:uppercase}
.post-title-text{font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:400}
.post-caption-area{margin-top:4px}
.caption-label{font-size:0.6rem;color:var(--gold);letter-spacing:0.12em;text-transform:uppercase;display:block;margin-bottom:3px}
.caption-editable{font-size:0.8rem;color:var(--black);line-height:1.5;border:none;background:transparent;width:100%;resize:none;font-family:'DM Sans',sans-serif;outline:none;cursor:text;min-height:40px}
.caption-editable:focus{background:#fffff8;border-radius:2px;padding:4px;outline:1px solid var(--gold-light)}
.photo-ref-text{font-size:0.65rem;color:#aaa;margin-top:2px}

/* PHOTO THUMB COL */
.post-photos-col{padding:0.8rem;display:flex;flex-direction:column;justify-content:center;gap:6px;border-left:1px solid var(--gray-light);min-width:80px;max-width:80px}
.thumb-wrap{width:56px;height:56px;overflow:hidden;cursor:pointer;border-radius:2px;border:1px solid var(--gray-light);position:relative;flex-shrink:0}
.thumb-wrap img{width:100%;height:100%;object-fit:cover;transition:transform 0.3s}
.thumb-wrap:hover img{transform:scale(1.05)}
.no-photo{width:56px;height:56px;background:var(--cream);border:1px dashed var(--gray-light);border-radius:2px;display:flex;align-items:center;justify-content:center;font-size:0.55rem;color:var(--gray);text-align:center;line-height:1.3;padding:4px}

/* SHOOTING DIVIDER */
.shooting-divider{background:var(--black);color:var(--white);padding:1.5rem 3rem;margin:2rem -3rem;display:flex;align-items:center;gap:2rem}
.shooting-divider h3{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:300}
.shooting-divider p{font-size:0.75rem;color:#888;letter-spacing:0.08em}
.shooting-badge{background:var(--gold);color:var(--black);font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;padding:4px 12px;border-radius:20px;font-weight:500;flex-shrink:0}

/* LIGHTBOX */
.lightbox{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.92);z-index:1000;align-items:center;justify-content:center;padding:2rem}
.lightbox.active{display:flex}
.lightbox-inner{position:relative;max-width:700px;max-height:85vh;width:100%}
.lightbox-inner img{width:100%;height:100%;object-fit:contain;border-radius:2px}
.lightbox-close{position:absolute;top:-2rem;right:0;background:none;border:none;color:white;font-size:1.5rem;cursor:pointer;letter-spacing:0.1em;font-family:'DM Sans',sans-serif}
.lightbox-caption{color:#aaa;font-size:0.75rem;text-align:center;margin-top:0.8rem;letter-spacing:0.08em}

/* SCRIPT SECTION */
.script-section{background:var(--cream);border:1px solid var(--gray-light);border-radius:2px;padding:2rem;margin-bottom:3rem}
.script-section h3{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:400;margin-bottom:1.2rem;padding-bottom:0.6rem;border-bottom:1px solid var(--gray-light)}
.script-block{margin-bottom:1.2rem}
.script-block-label{font-size:0.65rem;color:var(--gold);letter-spacing:0.15em;text-transform:uppercase;margin-bottom:4px}
.script-editable{font-size:0.82rem;line-height:1.7;border:none;background:white;width:100%;padding:0.8rem;border-radius:2px;resize:vertical;font-family:'DM Sans',sans-serif;color:var(--black);outline:none;cursor:text;border:1px solid transparent}
.script-editable:focus{border-color:var(--gold-light);outline:none}

/* PRINT / EXPORT */
.toolbar{position:sticky;bottom:0;background:var(--black);padding:0.8rem 3rem;display:flex;gap:1rem;align-items:center;z-index:100}
.toolbar p{font-size:0.7rem;color:#666;letter-spacing:0.08em;flex:1}
.btn{padding:7px 18px;font-size:0.72rem;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;border-radius:2px;font-family:'DM Sans',sans-serif;border:none}
.btn-gold{background:var(--gold);color:var(--black);font-weight:500}
.btn-outline{background:transparent;color:white;border:1px solid #444}
.save-notice{font-size:0.65rem;color:var(--gold);letter-spacing:0.08em;display:none}

@media print{
  .toolbar{display:none}
  .lightbox{display:none!important}
  .shooting-divider{margin:2rem 0}
  main{padding:1rem}
  .site-header{padding:1rem}
}
</style>
</head>
