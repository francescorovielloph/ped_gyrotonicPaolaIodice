document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('[data-post]').forEach(col => {
    const postId = col.dataset.post;
    const items = PHOTOS[postId] || [];
    if (items.length === 0) {
      col.innerHTML = '<div class="no-photo">Nessuna foto</div>';
      return;
    }
    items.forEach(item => {
      const wrap = document.createElement('div');
      wrap.className = 'thumb-wrap';
      const img = document.createElement('img');
      img.src = item.src;
      img.alt = item.name;
      wrap.appendChild(img);
      wrap.addEventListener('click', () => openLightbox(item.src, item.name));
      col.appendChild(wrap);
    });
  });

  document.querySelectorAll('.caption-editable, .script-editable').forEach(el => {
    el.addEventListener('input', () => {
      const n = document.getElementById('saveNotice');
      n.style.display = 'inline';
      setTimeout(() => n.style.display = 'none', 1500);
    });
  });
});

function openLightbox(src, name) {
  document.getElementById('lightbox-img').src = src;
  document.getElementById('lightbox-caption').textContent = name;
  document.getElementById('lightbox').classList.add('active');
}

function closeLightbox(e) {
  if (e.target === document.getElementById('lightbox')) {
    document.getElementById('lightbox').classList.remove('active');
  }
}

function exportHTML() {
  const captions = {};
  document.querySelectorAll('.caption-editable').forEach((el, i) => {
    captions['caption_' + i] = el.value;
  });
  const scripts = {};
  document.querySelectorAll('.script-editable').forEach((el, i) => {
    scripts['script_' + i] = el.value;
  });

  let html = document.documentElement.outerHTML;
  const blob = new Blob([html], {type: 'text/html'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'piano-editoriale-paola-iodice.html';
  a.click();
}
</script>
